        ]
      }
    ]
  },
  "@info": {
    "$ref": "#/$defs/nonEmptyString",
    "description": "Optional info text setup"
  },
  "@label": {
    "$ref": "#/$defs/stringOrTranslated",
    "description": "label is the new official replacement for headline"
  },
  "@layout": {
    "$ref": "#/$defs/nonEmptyString",
    "description": "Section layout"
  },
  "@limit": {
    "type": "number",
    "exclusiveMinimum": 0,
    "description": "Sets the number of items per page"
  },
  "@link": {
    "type": "boolean"
  },
  "@linkUrl": {
    "$ref": "#/$defs/nonEmptyString"
  },
  "@marks": {
    "oneOf": [
      {
        "type": "boolean"
      },
      {
        "type": "array",
        "items": {
          "$ref": "#/$defs/marks"
        }
      }
    ]
  },
  "@max": {
    "type": "number"
  },
  "@maxlength": {
    "type": "number"
  },
  "@min": {
    "type": "number"
  },
  "@minlength": {
    "type": "number"
  },
  "@multiple": {
    "type": "boolean",
    "description": "If false, only a single one can be selected"
  },
  "@nodes": {
    "oneOf": [
      {
        "type": "boolean"
      },
      {
        "type": "array",
        "items": {
          "$ref": "#/$defs/nodes"
        }
      }
    ]
  },
  "@options": {
    "anyOf": [
      {
        "$ref": "#/$defs/stringOrStringArrayUnique"
      },
      {
        "$ref": "#/$defs/optionsArray"
      },
      {
        "$ref": "#/$defs/optionsMap"
      },
      {
        "$ref": "#/$defs/optionsProvider"
      }
    ]
  },
  "@page": {
    "type": "number",
    "exclusiveMinimum": 0,
    "description": "Sets the default page for the pagination"
  },
  "@parent": {
    "$ref": "#/$defs/nonEmptyString",
    "description": "Sets the query to a parent to find items for the list"
  },
  "@pattern": {
    "$ref": "#/$defs/nonEmptyString",
    "description": "A regular expression, which will be used to validate the input"
  },
  "@placeholder": {
    "$ref": "#/$defs/stringOrTranslated"
  },
  "@query": {
    "oneOf": [
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "$ref": "#/$defs/queryObject"
      }
    ]
  },
  "@required": {
    "type": "boolean"
  },
  "@search": {
    "oneOf": [
      {
        "type": "boolean"
      },
      {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "min": {
            "type": "number"
          },
          "display": {
            "$ref": "#/$defs/stringOrTranslated"
          },
          "info": {
            "$ref": "#/$defs/stringOrTranslated"
          },
          "placeholder": {
            "$ref": "#/$defs/stringOrTranslated"
          }
        }
      }
    ]
  },
  "@separator": {
    "$ref": "#/$defs/nonEmptyString"
  },
  "@size": {
    "enum": [
      "tiny",
      "small",
      "medium",
      "large",
      "huge",
      "auto",
      "full"
    ],
    "description": "The size option controls the size of cards"
  },
  "@sortBy": {
    "$ref": "#/$defs/nonEmptyString",
    "description": "Overwrites manual sorting and sorts by the given field and sorting direction"
  },
  "@sort": {
    "type": "boolean"
  },
  "@sortable": {
    "type": "boolean",
    "description": "Enables/disables manual sorting"
  },
  "@store": {
    "enum": [
      "uuid",
      "id"
    ],
    "description": "Whether to store UUID or ID in the content file of the model",
    "default": "uuid"
  },
  "@spellcheck": {
    "type": "boolean"
  },
  "@step": {
    "oneOf": [
      {
        "type": "number"
      },
      {
        "$ref": "#/$defs/nonEmptyString"
      }
    ]
  },
  "@status": {
    "enum": [
      "draft",
      "unlisted",
      "listed",
      "published",
      "all"
    ]
  },
  "@template": {
    "$ref": "#/$defs/stringOrStringArrayUnique",
    "description": "Filters all files by template and also sets the template, which will be used for all uploads"
  },
  "@templates": {
    "oneOf": [
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "$ref": "#/$defs/stringArrayUnique"
      }
    ]
  },
  "@text": {
    "$ref": "#/$defs/stringOrTranslated",
    "description": "Setup for the main text in the list or cards"
  },
  "@theme": {
    "enum": [
      "none",
      "positive",
      "info",
      "negative",
      "warning",
      "notice",
      "love",
      "passive",
      "text",
      "dark",
      "code",
      "empty"
    ]
  },
  "@toolbar": {
    "oneOf": [
      {
        "$ref": "#/$defs/objectWithStringValues"
      },
      {
        "type": "object",
        "properties": {
          "marks": {
            "type": "array"
          },
          "nodes": {
            "type": "array"
          },
          "inline": {
            "type": "boolean"
          }
        }
      }
    ]
  },
  "@translate": {
    "type": "boolean"
  },
  "@uploads": {
    "oneOf": [
      {
        "$ref": "#/$defs/booleanOrString"
      },
      {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "parent": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "template": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "$ref": "#/$defs/nonEmptyString"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "parent": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "template": {
                  "$ref": "#/$defs/nonEmptyString"
                }
              }
            }
          ]
        }
      }
    ]
  },
  "@value": {
    "$ref": "#/$defs/stringOrNumber"
  },
  "@when": {
    "oneOf": [
      {
        "$ref": "#/$defs/objectWithBooleanOrNonEmptyStringValues"
      }
    ]
  },
  "@width": {
    "enum": [
      "1/1",
      "1/2",
      "1/3",
      "1/4",
      "2/3",
      "3/4"
    ],
    "default": "1/1"
  },
  "@pickerQuery": {
    "$ref": "#/$defs/notRequiredNonEmptyString"
  },
  "@pickerSearch": {
    "type": "boolean"
  },
  "@dateTimeBoundary": {
    "$ref": "#/$defs/notRequiredNonEmptyString"
  },
  "@dateTimeStep": {
    "oneOf": [
      {
        "type": "number"
      },
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "unit": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "size": {
            "type": "number"
          }
        }
      }
    ]
  },
  "@numericStep": {
    "oneOf": [
      {
        "type": "number"
      },
      {
        "enum": [
          "any"
        ]
      }
    ]
  },
  "@rangeTooltip": {
    "oneOf": [
      {
        "type": "boolean"
      },
      {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "before": {
            "$ref": "#/$defs/stringOrTranslated"
          },
          "after": {
            "$ref": "#/$defs/stringOrTranslated"
          }
        }
      }
    ]
  },
  "@sectionLayout": {
    "enum": [
      "list",
      "cardlets",
      "cards",
      "table"
    ]
  },
  "@filesSectionCreate": {
    "type": "boolean"
  },
  "@pagesSectionCreate": {
    "oneOf": [
      {
        "type": "boolean"
      },
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "$ref": "#/$defs/stringArrayUnique"
      }
    ]
  },
  "@pagesSectionStatus": {
    "enum": [
      "draft",
      "drafts",
      "unlisted",
      "listed",
      "published",
      "all"
    ]
  },
  "@filesSectionTemplate": {
    "$ref": "#/$defs/notRequiredNonEmptyString"
  },
  "@linkOptions": {
    "type": "array",
    "items": {
      "enum": [
        "url",
        "page",
        "file",
        "email",
        "tel",
        "anchor",
        "custom"
      ]
    },
    "uniqueItems": true,
    "minItems": 1
  },
  "@toggleText": {
    "oneOf": [
      {
        "$ref": "#/$defs/stringOrTranslated"
      },
      {
        "type": "array",
        "minItems": 1,
        "maxItems": 2,
        "items": {
          "$ref": "#/$defs/stringOrTranslated"
        }
      }
    ]
  },
  "@slugOption": {
    "oneOf": [
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "type": "null"
      },
      {
        "const": false
      }
    ]
  },
  "@statsSize": {
    "enum": [
      "small",
      "medium",
      "large",
      "huge"
    ]
  }
}
