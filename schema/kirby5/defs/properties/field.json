          "box",
          "brush",
          "bug",
          "calendar",
          "cancel",
          "cancel-small",
          "car",
          "cart",
          "chart",
          "chat",
          "check",
          "checklist",
          "circle",
          "circle-filled",
          "circle-filled",
          "circle-half",
          "circle-nested",
          "circle-outline",
          "clear",
          "clock",
          "cloud",
