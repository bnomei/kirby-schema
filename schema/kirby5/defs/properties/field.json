{
  "@after": {
    "$ref": "#/$defs/stringOrTranslated"
  },
  "@api": {
    "oneOf": [
      {
        "$ref": "#/$defs/booleanOrString"
      },
      {
        "$ref": "#/$defs/queryObject"
      }
    ]
  },
  "@autocomplete": {
    "$ref": "#/$defs/nonEmptyString"
  },
  "@align": {
    "enum": [
      "left",
      "center",
      "right"
    ],
    "default": "left"
  },
  "@autofocus": {
    "type": "boolean"
  },
  "@batch": {
    "type": "boolean"
  },
  "@before": {
    "$ref": "#/$defs/stringOrTranslated"
  },
  "@buttons": {
    "oneOf": [
      {
        "type": "boolean"
      },
      {
        "type": "array",
        "items": {
          "enum": [
            "headlines",
            "italic",
            "bold",
            "link",
            "email",
            "file",
            "code",
            "ul",
            "ol",
            "|"
          ]
        }
      }
    ]
  },
  "@columns": {
    "type": "object",
    "patternProperties": {
      ".*": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "properties": {
              "label": {
                "$ref": "#/$defs/field-properties/@label"
              },
              "align": {
                "$ref": "#/$defs/field-properties/@align"
              },
              "width": {
                "$ref": "#/$defs/fraction"
              },
              "value": {
                "$ref": "#/$defs/field-properties/@value"
              }
            }
          }
        ]
      }
    }
  },
  "@converter": {
    "enum": [
      "lower",
      "upper",
      "ucfirst",
      "slug"
    ]
  },
  "@counter": {
    "type": "boolean"
  },
  "@create": {
    "oneOf": [
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "$ref": "#/$defs/booleanOrStringArrayUnique"
      }
    ]
  },
  "@default": {
    "$ref": "#/$defs/arrayOrBooleanOrNumberOrObjectOrString",
    "description": "Default value for the field, which will be used when a page/file/user is created"
  },
  "@disabled": {
    "type": "boolean"
  },
  "@empty": {
    "$ref": "#/$defs/stringOrTranslated",
    "description": "Sets the text for the empty state box"
  },
  "@extends": {
    "$ref": "#/$defs/nonEmptyString"
  },
  "@fieldsets": {
    "anyOf": [
      {
        "$ref": "#/$defs/stringArrayUnique"
      },
      {
        "type": "array",
        "items": {
          "$ref": "#/$defs/fieldsetsItem"
        }
      },
      {
        "type": "object",
        "patternProperties": {
          ".*": {
            "$ref": "#/$defs/fieldsetEntry"
          }
        }
      }
    ]
  },
  "@files": {
    "oneOf": [
      {
        "$ref": "#/$defs/nonEmptyString"
      },
      {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "query": {
            "$ref": "#/$defs/field-properties/@pickerQuery"
          },
          "image": {
            "$ref": "#/$defs/field-properties/@image"
          }
        }
      }
    ]
  },
  "@flip": {
    "type": "boolean",
    "description": "Enables/disables reverse sorting"
  },
  "@font": {
    "enum": [
      "sans",
      "monospace"
    ],
    "description": "Sets the font family (sans or monospace)",
    "default": "sans"
  },
  "@headings": {
    "type": "array",
    "items": {
      "type": "integer",
      "enum": [
        1,
        2,
        3,
        4,
        5,
        6
      ]
    }
  },
  "@headline": {
    "$ref": "#/$defs/stringOrTranslated"
  },
  "@help": {
    "$ref": "#/$defs/stringOrTranslated",
    "description": "Optional help text below the field"
  },
  "@image": {
    "oneOf": [
      {
        "$ref": "#/$defs/booleanOrString"
      },
      {
        "type": "object",
        "properties": {
          "back": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "color": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "cover": {
            "type": "boolean"
          },
          "icon": {
            "$ref": "#/$defs/field-properties/@icon"
          },
          "ratio": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "query": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    ],
    "description": "Image options to control the source and look of file previews"
  },
  "@icon": {
