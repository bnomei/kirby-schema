{
  "type": "object",
  "anyOf": [
    {
      "required": [
        "type"
      ]
    },
    {
      "required": [
        "extends"
      ]
    }
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "enum": [
        "stats"
      ]
    },
    "blueprint": {
      "enum": [
        "section"
      ]
    },
    "extends": {
      "$ref": "#/$defs/field-properties/@extends"
    },
    "headline": {
      "$ref": "#/$defs/field-properties/@headline"
    },
    "label": {
      "$ref": "#/$defs/field-properties/@label"
    },
    "reports": {
      "$ref": "#/$defs/blueprint-properties/@reports"
    },
    "size": {
      "$ref": "#/$defs/field-properties/@statsSize",
      "default": "large"
    },
    "when": {
      "$ref": "#/$defs/field-properties/@when"
    }
  }
}
